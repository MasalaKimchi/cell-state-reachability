# External scientific data: retain instructions, never commit payloads.
data/*
!data/.gitkeep
!data/README.md
!data/fetch_de_stats.sh

# Removed analysis surfaces must not reappear as local caches.
analysis_cache/
outputs/

# Cross-dataset effect-matrix caches (large, local, and required by exact byte identity;
# see data/README.md for reconstruction and durable-availability boundaries). Never commit.
slice/

# Exploratory baseline-ladder scratch is not claim-bearing until it has a checked-in,
# hash-bound runner and frozen configuration.
analysis/*

# Python and environments.
__pycache__/
*.py[cod]
.pytest_cache/
.ipynb_checkpoints/
build/
dist/
*.egg-info/
.venv/
.env

# Generated/editor/OS debris.
*.log
.DS_Store

# Local agent operating manuals.
AGENTS.md
CLAUDE.md
.claude/
